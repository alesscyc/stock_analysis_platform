# ── Interactive Brokers Gateway ─────────────────────────────────────
# Required: these must be set before starting the server
IB_HOST=127.0.0.1
IB_PORT=4001
IB_CLIENT_ID=1

# Timeout for waiting for IB portfolio snapshots (milliseconds)
IB_PORTFOLIO_SYNC_TIMEOUT_MS=30000

# Timeout for waiting for IB order ID (milliseconds)
IB_ORDER_ID_WAIT_TIMEOUT_MS=15000

# Timeout for waiting for IB open-order snapshots (milliseconds)
IB_OPEN_ORDERS_SYNC_TIMEOUT_MS=15000

# ── Finnhub API ─────────────────────────────────────────────────────
# Optional: symbol search degrades gracefully without this key
FINNHUB_KEY=your_finnhub_api_key_here

# ── Python FastAPI service ──────────────────────────────────────────
# Optional: defaults to http://127.0.0.1:8000
PYTHON_SERVICE_URL=http://127.0.0.1:8000
